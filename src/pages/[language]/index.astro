---
import Base from '@/layouts/Base.astro';
import Banner from '@/components/Banner.astro';
import { languages, useTranslations, type LanguageKey } from '@/i18n/i18n.ts';
import { defaultLocale } from '@/i18n/i18n.ts';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getCollection, getEntry } from 'astro:content';
import DOMPurify from 'isomorphic-dompurify';

const currentLocale = Astro.currentLocale as LanguageKey;
const config = await getEntry('config', 'site');
const { website: { username } } = config!.data;
const resume = (await getEntry('resume', currentLocale))?.data;
const publicCurrentLangProjects = await getCollection('project', (project) => {
  const isPublicProject = !project.data.draft;
  const isCurrentLangProject = project.id.startsWith(currentLocale);
  return isPublicProject && isCurrentLangProject;
});
const featuredProjects = publicCurrentLangProjects
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
const t = useTranslations(currentLocale);

export function getStaticPaths() {
  return Object.keys(languages).map((language) => ({
    params: { language },
  }));
}
---

<Base title={t('Navbar-1')}>
  <main class="md:min-h-screen min-h-auto">
    <Banner>
      <div class="px-4 grid gap-10 lg:grid-cols-[1.4fr_0.8fr] items-start">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="uppercase tracking-[0.2em] text-sm text-primary-600">Portfolio / Resume / Case Studies</p>
            <h1 class="text-4xl md:text-7xl font-semibold leading-tight">
              {t('Hero-Greeting', { name: username })}
            </h1>
            <p class="max-w-4xl text-lg md:text-2xl font-serif text-primary-700">
              {t('Hero-Intro')}
            </p>
            <p class="max-w-3xl text-base md:text-lg text-primary-600">
              <Fragment set:html={DOMPurify.sanitize(t('Hero-CTA', {
                articlesLink: `<a class="highlight" href="${getRelativeLocaleUrl(Astro.currentLocale || defaultLocale, '/work')}">${t('Hero-BlogLink')}</a>`,
                resumeLink: `<a class="highlight" href="${getRelativeLocaleUrl(Astro.currentLocale || defaultLocale, '/resume')}">${t('Hero-Resume')}</a>`,
              }))} />
            </p>
          </div>

          {resume && (
            <div class="rounded-[2rem] border border-primary-200 bg-white/80 p-6 md:p-8 shadow-[0_20px_60px_rgba(41,74,72,0.08)] backdrop-blur">
              <div class="grid gap-4 md:grid-cols-3">
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">方向聚焦</p>
                  <p class="mt-2 text-lg font-medium">医疗健康产品 / 医学内容 / 数字疗法</p>
                </div>
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">核心闭环</p>
                  <p class="mt-2 text-lg font-medium">评估、治疗、报告三大模块设计</p>
                </div>
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">方法背景</p>
                  <p class="mt-2 text-lg font-medium">心理学研究、脑科学内容设计、R 统计分析</p>
                </div>
              </div>
            </div>
          )}
        </div>

        <div class="grid gap-4">
          <div class="rounded-[2rem] bg-primary-900 text-primary-50 p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.16em] text-primary-300">代表成果</p>
            <ul class="mt-5 space-y-4 text-lg">
              <li>10 个脑电反馈游戏方案</li>
              <li>8 个心理治疗指导语脚本定稿</li>
              <li>4 类标准化报告模板</li>
              <li>覆盖 ICD-11 / DSM-5 标签体系梳理</li>
            </ul>
          </div>
          <div class="rounded-[2rem] border border-primary-200 bg-[#f7f1e8] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.16em] text-[#8d6a2f]">个人简介</p>
            <div class="mt-4 text-base leading-8 text-primary-800 font-serif" set:html={DOMPurify.sanitize(resume?.personalInfo.description || '')}></div>
          </div>
        </div>
      </div>
    </Banner>

    <section class="mb-20 container mx-auto px-4">
      <div class="grid gap-6 md:grid-cols-4">
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">产品定义</p>
          <p class="mt-3 text-lg text-primary-800">围绕适应症、反馈机制、指标体系与交互逻辑完成方案梳理。</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">临床流程</p>
          <p class="mt-3 text-lg text-primary-800">搭建评估、治疗、报告闭环，推动内容从概念走向可交付。</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">数据规则</p>
          <p class="mt-3 text-lg text-primary-800">定义复合指标、阈值、得分逻辑、展示规则与存储要求。</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">协作落地</p>
          <p class="mt-3 text-lg text-primary-800">连接产品、研发、设计、算法与外部供应商，推进版本交付。</p>
        </div>
      </div>
    </section>

    <section class="mb-24 container mx-auto px-4">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
        <div>
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('NewestWork-1')}</p>
          <h2 class="text-3xl md:text-5xl font-semibold mt-2">把医学逻辑转成产品方案的三个案例</h2>
        </div>
        <a class="rounded-full border border-primary-300 px-5 py-3 hover:bg-primary-100 transition-colors" href={getRelativeLocaleUrl(Astro.currentLocale || defaultLocale, '/work')}>
          查看全部案例
        </a>
      </div>

      <ul class="grid gap-6 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <li class="rounded-[2rem] border border-primary-200 bg-white p-6 md:p-8 shadow-[0_18px_60px_rgba(41,74,72,0.06)]">
            <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{project.data.publishDate.getFullYear()}</p>
            <h3 class="mt-3 text-2xl font-semibold">{project.data.title}</h3>
            <p class="mt-4 text-lg font-serif text-primary-700">{project.data.description}</p>
            <ul class="mt-6 flex flex-wrap gap-2">
              {project.data.tech.map((tech) => (
                <li class="rounded-full bg-primary-100 px-3 py-1 text-sm text-primary-700">{tech}</li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Base>
