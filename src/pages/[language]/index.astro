---
import Base from '@/layouts/Base.astro';
import Banner from '@/components/Banner.astro';
import { languages, useTranslations, defaultLocale, getLocalePath, type LanguageKey } from '@/i18n/i18n.ts';
import { getCollection, getEntry } from 'astro:content';
import DOMPurify from 'isomorphic-dompurify';
import { getTechLabel } from '@/utils/tech.ts';

const currentLocale = Astro.currentLocale as LanguageKey;
const resume = (await getEntry('resume', currentLocale))?.data;
const publicCurrentLangProjects = await getCollection('project', (project) => {
  const isPublicProject = !project.data.draft;
  const isCurrentLangProject = project.id.startsWith(currentLocale);
  return isPublicProject && isCurrentLangProject;
});
const featuredProjects = publicCurrentLangProjects
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
const t = useTranslations(currentLocale);
const displayName = t('Person-Name');

export function getStaticPaths() {
  return Object.keys(languages).map((language) => ({
    params: { language },
  }));
}
---

<Base title={t('Navbar-1')}>
  <main class="md:min-h-screen min-h-auto">
    <Banner>
      <div class="px-4 grid gap-10 lg:grid-cols-[1.4fr_0.8fr] items-start">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="uppercase tracking-[0.2em] text-sm text-primary-600">{t('Home-Eyebrow')}</p>
            <h1 class="text-4xl md:text-7xl font-semibold leading-tight">
              {t('Hero-Greeting', { name: displayName })}
            </h1>
            <p class="max-w-4xl text-lg md:text-2xl font-serif text-primary-700">
              {t('Hero-Intro')}
            </p>
            <p class="max-w-3xl text-base md:text-lg text-primary-600">
              <Fragment
                set:html={DOMPurify.sanitize(
                  t('Hero-CTA', {
                    articlesLink: `<a class="highlight" href="${getLocalePath(Astro.currentLocale as LanguageKey || defaultLocale, '/work')}">${t('Hero-BlogLink')}</a>`,
                    resumeLink: `<a class="highlight" href="${getLocalePath(Astro.currentLocale as LanguageKey || defaultLocale, '/resume')}">${t('Hero-Resume')}</a>`,
                  }),
                )}
              />
            </p>
          </div>

          {resume && (
            <div class="rounded-[2rem] border border-primary-200 bg-white/80 p-6 md:p-8 shadow-[0_20px_60px_rgba(41,74,72,0.08)] backdrop-blur">
              <div class="grid gap-4 md:grid-cols-3">
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Summary-1-Label')}</p>
                  <p class="mt-2 text-lg font-medium">{t('Home-Summary-1-Value')}</p>
                </div>
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Summary-2-Label')}</p>
                  <p class="mt-2 text-lg font-medium">{t('Home-Summary-2-Value')}</p>
                </div>
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Summary-3-Label')}</p>
                  <p class="mt-2 text-lg font-medium">{t('Home-Summary-3-Value')}</p>
                </div>
              </div>
            </div>
          )}
        </div>

        <div class="grid gap-4">
          <div class="rounded-[2rem] bg-primary-900 text-primary-50 p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.16em] text-primary-300">{t('Home-Spotlight-Label')}</p>
            <ul class="mt-5 space-y-4 text-lg">
              <li>{t('Home-Spotlight-1')}</li>
              <li>{t('Home-Spotlight-2')}</li>
              <li>{t('Home-Spotlight-3')}</li>
              <li>{t('Home-Spotlight-4')}</li>
            </ul>
          </div>
          <div class="rounded-[2rem] border border-primary-200 bg-[#f7f1e8] p-6 md:p-8">
            <p class="text-sm uppercase tracking-[0.16em] text-[#8d6a2f]">{t('Home-Profile-Label')}</p>
            <div
              class="mt-4 text-base leading-8 text-primary-800 font-serif"
              set:html={DOMPurify.sanitize(resume?.personalInfo.description || '')}
            ></div>
          </div>
        </div>
      </div>
    </Banner>

    <section class="mb-20 container mx-auto px-4">
      <div class="grid gap-6 md:grid-cols-4">
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Highlights-1-Title')}</p>
          <p class="mt-3 text-lg text-primary-800">{t('Home-Highlights-1-Description')}</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Highlights-2-Title')}</p>
          <p class="mt-3 text-lg text-primary-800">{t('Home-Highlights-2-Description')}</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Highlights-3-Title')}</p>
          <p class="mt-3 text-lg text-primary-800">{t('Home-Highlights-3-Description')}</p>
        </div>
        <div class="rounded-[1.5rem] border border-primary-200 bg-white p-6">
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('Home-Highlights-4-Title')}</p>
          <p class="mt-3 text-lg text-primary-800">{t('Home-Highlights-4-Description')}</p>
        </div>
      </div>
    </section>

    <section class="mb-24 container mx-auto px-4">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
        <div>
          <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{t('NewestWork-1')}</p>
          <h2 class="text-3xl md:text-5xl font-semibold mt-2">{t('Home-FeatureSection-Title')}</h2>
        </div>
        <a
          class="rounded-full border border-primary-300 px-5 py-3 hover:bg-primary-100 transition-colors"
          href={getLocalePath(Astro.currentLocale as LanguageKey || defaultLocale, '/work')}
        >
          {t('Home-FeatureSection-CTA')}
        </a>
      </div>

      <ul class="grid gap-6 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <li class="rounded-[2rem] border border-primary-200 bg-white p-6 md:p-8 shadow-[0_18px_60px_rgba(41,74,72,0.06)]">
            <p class="text-sm uppercase tracking-[0.16em] text-primary-500">{project.data.publishDate.getFullYear()}</p>
            <h3 class="mt-3 text-2xl font-semibold">{project.data.title}</h3>
            <p class="mt-4 text-lg font-serif text-primary-700">{project.data.description}</p>
            <ul class="mt-6 flex flex-wrap gap-2">
              {project.data.tech.map((tech) => (
                <li class="rounded-full bg-primary-100 px-3 py-1 text-sm text-primary-700">{getTechLabel(tech, currentLocale)}</li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Base>
