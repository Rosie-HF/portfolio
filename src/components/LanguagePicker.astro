---
import { languages, useTranslations, changeLanguage, type LanguageKey } from '@/i18n/i18n.ts';

const t = useTranslations(Astro.currentLocale as LanguageKey);
const hasMultipleLanguages = Object.keys(languages).length > 1;
---

{
  hasMultipleLanguages && (
    <nav
      aria-label={t('LanguagePicker-1')}
      class="inline-flex items-center gap-1 rounded-full border border-primary-200 bg-white/90 p-1 shadow-sm backdrop-blur"
    >
      {Object.entries(languages).map(([key, name]) => {
        const isCurrentLocale = Astro.currentLocale === key;
        const shortLabel = key === 'zh-cn' ? '中' : 'EN';

        return isCurrentLocale ? (
          <span
            aria-current="page"
            class="inline-flex min-w-12 items-center justify-center rounded-full bg-primary-900 px-4 py-2 text-sm font-semibold text-primary-50"
            title={name}
          >
            {shortLabel}
          </span>
        ) : (
          <a
            class="inline-flex min-w-12 items-center justify-center rounded-full px-4 py-2 text-sm font-semibold text-primary-700 transition-colors hover:bg-primary-100 hover:text-primary-900"
            href={changeLanguage(key as LanguageKey, Astro.url.pathname)}
            title={name}
          >
            {shortLabel}
          </a>
        );
      })}
    </nav>
  )
}
